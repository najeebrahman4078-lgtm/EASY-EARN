{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information, balances, and referral data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number", "description": "Main balance in USD" },
        "coinBalance": { "type": "number", "description": "Balance in MR COIN (1.2 USD each)" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "viewCount": { "type": "number", "description": "Total views generated by this user" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "balance", "coinBalance", "referralCode", "role"]
    },
    "Machine": {
      "title": "Mining Machine",
      "description": "Definition of a mining machine available for rent.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "dailyIncome": { "type": "number" },
        "duration": { "type": "number", "description": "Duration in days" },
        "image": { "type": "string", "description": "URL to 3D icon image" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "price", "dailyIncome", "duration", "image"]
    },
    "UserMachine": {
      "title": "User Rented Machine",
      "description": "Records of machines rented by users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "machineId": { "type": "string" },
        "machineName": { "type": "string" },
        "dailyIncome": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "lastCollectedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "machineId", "machineName", "dailyIncome", "timestamp", "expiresAt", "lastCollectedAt"]
    },
    "Transaction": {
      "title": "Financial Transaction",
      "description": "Records of deposits and withdrawals.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "method": { "type": "string", "enum": ["Easypaisa", "OKX", "Bank Transfer"] },
        "details": { "type": "string", "description": "Account number or wallet address" },
        "txId": { "type": "string", "description": "Transaction ID or reference for deposits" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "status", "method", "details", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/machines/{machineId}": {
      "schema": "Machine",
      "description": "Available mining machines."
    },
    "/userMachines/{userMachineId}": {
      "schema": "UserMachine",
      "description": "User machine rentals."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Deposit and withdrawal records."
    }
  }
}
